<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.techmeeva.chogadiyawidgets.features.onboarding.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboarding_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.techmeeva.chogadiyawidgets.features.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/calendarFragment"
        android:name="com.techmeeva.chogadiyawidgets.features.calendar.CalendarFragment"
        android:label="Calendar"
        tools:layout="@layout/fragment_calendar" />

    <fragment
        android:id="@+id/skyFragment"
        android:name="com.techmeeva.chogadiyawidgets.features.sky.SkyFragment"
        android:label="Sky"
        tools:layout="@layout/fragment_sky" />

    <fragment
        android:id="@+id/panchangFragment"
        android:name="com.techmeeva.chogadiyawidgets.features.panchang.PanchangFragment"
        android:label="Panchang"
        tools:layout="@layout/fragment_panchang" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.techmeeva.chogadiyawidgets.features.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />
</navigation>
