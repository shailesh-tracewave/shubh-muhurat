<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Night/Dark Mode). -->
    <style name="Theme.ChoghadiyaApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/celestial_primary</item>
        <item name="colorPrimaryVariant">@color/celestial_primary_strong</item>
        <item name="colorOnPrimary">@color/celestial_white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/celestial_secondary</item>
        <item name="colorSecondaryVariant">@color/celestial_secondary_container</item>
        <item name="colorOnSecondary">@color/celestial_white</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/celestial_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/celestial_surface</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Background and surface. -->
        <item name="android:windowBackground">@color/celestial_background</item>
        <item name="colorSurface">@color/celestial_surface</item>
        <item name="colorOnSurface">@color/celestial_text</item>
    </style>

    <!-- Premium Native Splash Screen Theme -->
    <style name="Theme.ChoghadiyaApp.Splash" parent="Theme.ChoghadiyaApp">
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>
</resources>
