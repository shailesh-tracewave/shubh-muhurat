<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ChoghadiyaApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/celestial_primary</item>
        <item name="colorPrimaryVariant">@color/celestial_primary_strong</item>
        <item name="colorOnPrimary">@color/celestial_white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/celestial_secondary</item>
        <item name="colorSecondaryVariant">@color/celestial_secondary_container</item>
        <item name="colorOnSecondary">@color/celestial_white</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/celestial_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/celestial_surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Background and surface. -->
        <item name="android:windowBackground">@color/celestial_background</item>
        <item name="colorSurface">@color/celestial_surface</item>
        <item name="colorOnSurface">@color/celestial_text</item>
    </style>

    <!-- Premium Native Splash Screen Theme -->
    <style name="Theme.ChoghadiyaApp.Splash" parent="Theme.ChoghadiyaApp">
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>

    <!-- Circular Image Shape -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="PanchangMetricText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:textColor">@color/celestial_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="PanchangSectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/celestial_outline</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PanchangSectionContainer">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="TextAppearance.Choghadiya.BottomNavigation.Active" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="TextAppearance.Choghadiya.BottomNavigation.Inactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:maxLines">1</item>
    </style>
</resources>
