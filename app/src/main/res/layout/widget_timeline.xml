<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Row 1: Header / Top Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_label_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current"
                android:textColor="@color/celestial_text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"
                android:singleLine="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/bg_circle_solid" />

                <TextView
                    android:id="@+id/widget_active_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Udveg"
                    android:textColor="@color/celestial_text"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_active_meaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="Tense"
                android:textColor="@color/celestial_text_muted"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right Side Logo -->

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Row 2: Countdown 00:22 Left -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:22"
            android:textColor="@color/choghadiya_udveg"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_label_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="6dp"
            android:text="Left"
            android:textColor="@color/celestial_text_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Row 3: Progress Bar -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="4dp"
        android:max="100"
        android:progress="60"
        android:progressTint="@color/choghadiya_udveg"
        android:progressBackgroundTint="@color/celestial_border" />

    <!-- Row 4: 9:57 PM - 11:17 PM Range -->
    <TextView
        android:id="@+id/widget_active_range"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="9:57 PM - 11:17 PM"
        android:textColor="@color/celestial_text_muted"
        android:textSize="11sp"
        android:layout_marginBottom="4dp"
        android:singleLine="true" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/celestial_border"
        android:alpha="0.3"
        android:layout_marginBottom="6dp" />

    <!-- Row 5: Next 3 Horizontal Slots -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Col 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_next_1_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:src="@drawable/bg_circle_solid"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/widget_next_1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shubh"
                android:textColor="@color/celestial_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />
            <TextView
                android:id="@+id/widget_next_1_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:36 AM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/celestial_border"
            android:alpha="0.3" />

        <!-- Col 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_next_2_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:src="@drawable/bg_circle_solid"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/widget_next_2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amrit"
                android:textColor="@color/celestial_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />
            <TextView
                android:id="@+id/widget_next_2_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1:56 AM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/celestial_border"
            android:alpha="0.3" />

        <!-- Col 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_next_3_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:src="@drawable/bg_circle_solid"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/widget_next_3_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chal"
                android:textColor="@color/celestial_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />
            <TextView
                android:id="@+id/widget_next_3_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3:15 AM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
