<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celestial_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panchang_header"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@color/celestial_background"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/panchang_title_icon_container"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_sparkles"
                app:tint="@color/celestial_primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/panchang_title_icon_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/panchang_title_icon_container"
            app:layout_constraintTop_toTopOf="@id/panchang_title_icon_container">

            <TextView
                android:id="@+id/tv_panchang_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:singleLine="true"
                android:text="Panchang"
                android:textColor="@color/celestial_text"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_panchang_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Ahmedabad • 2 Jul" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/celestial_border"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/panchang_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:id="@+id/panchang_loading_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_inline_notice"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:indeterminateTint="@color/celestial_primary_strong" />

                <TextView
                    android:id="@+id/tv_panchang_loading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="Updating Panchang" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panchang_error_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_inline_notice"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wifi_off"
                    app:tint="@color/celestial_warning" />

                <TextView
                    android:id="@+id/tv_panchang_error_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:textColor="@color/celestial_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_panchang_error_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_panchang_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gold_button"
                    android:backgroundTint="@null"
                    android:minWidth="132dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textColor="@color/celestial_on_gold"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panchang_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/card_panchang_hero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/tv_panchang_weekday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:textColor="@color/celestial_outline"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="THURSDAY" />

                    <TextView
                        android:id="@+id/tv_panchang_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:textColor="@color/celestial_text"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        tools:text="2 July 2026" />

                    <LinearLayout
                        android:id="@+id/limbs_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/card_panchang_metrics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <TextView
                            android:id="@+id/tv_panchang_sunrise"
                            style="@style/PanchangMetricText"
                            android:text="Sunrise\n--:--" />

                        <TextView
                            android:id="@+id/tv_panchang_sunset"
                            style="@style/PanchangMetricText"
                            android:text="Sunset\n--:--" />

                        <TextView
                            android:id="@+id/tv_panchang_moonrise"
                            style="@style/PanchangMetricText"
                            android:text="Moonrise\n--:--" />

                        <TextView
                            android:id="@+id/tv_panchang_moonset"
                            style="@style/PanchangMetricText"
                            android:text="Moonset\n--:--" />

                        <TextView
                            android:id="@+id/tv_panchang_noon"
                            style="@style/PanchangMetricText"
                            android:text="Solar Noon\n--:--" />

                        <TextView
                            android:id="@+id/tv_panchang_illumination"
                            style="@style/PanchangMetricText"
                            android:text="Illumination\n--%" />
                    </GridLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_rashi_header"
                    style="@style/PanchangSectionHeader"
                    android:text="RASHI &amp; NAKSHATRA" />
                <LinearLayout
                    android:id="@+id/rashi_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_time_header"
                    style="@style/PanchangSectionHeader"
                    android:text="DAY DETAILS" />
                <LinearLayout
                    android:id="@+id/ritu_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_auspicious_header"
                    style="@style/PanchangSectionHeader"
                    android:text="AUSPICIOUS WINDOWS" />
                <LinearLayout
                    android:id="@+id/auspicious_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_inauspicious_header"
                    style="@style/PanchangSectionHeader"
                    android:text="INAUSPICIOUS WINDOWS" />
                <LinearLayout
                    android:id="@+id/inauspicious_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_nivas_header"
                    style="@style/PanchangSectionHeader"
                    android:text="NIVAS &amp; SHOOL" />
                <LinearLayout
                    android:id="@+id/nivas_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_bala_header"
                    style="@style/PanchangSectionHeader"
                    android:text="BALA" />
                <LinearLayout
                    android:id="@+id/bala_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_epochs_header"
                    style="@style/PanchangSectionHeader"
                    android:text="CALENDAR SYSTEMS" />
                <LinearLayout
                    android:id="@+id/epochs_container"
                    style="@style/PanchangSectionContainer" />

                <TextView
                    android:id="@+id/tv_lagna_header"
                    style="@style/PanchangSectionHeader"
                    android:text="UDAYA LAGNA" />
                <LinearLayout
                    android:id="@+id/lagna_container"
                    style="@style/PanchangSectionContainer" />

                <LinearLayout
                    android:id="@+id/notes_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
