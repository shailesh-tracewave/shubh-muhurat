<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celestial_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@color/celestial_background"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/home_title_icon_container"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_sparkles"
                app:tint="@color/celestial_primary" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/home_title_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/home_title_icon_container"
            app:layout_constraintEnd_toStartOf="@id/btn_sky_shortcut"
            app:layout_constraintStart_toEndOf="@id/home_title_icon_container"
            app:layout_constraintTop_toTopOf="@id/home_title_icon_container">

            <TextView
                android:id="@+id/tv_home_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:singleLine="true"
                android:text="Shubh Muhurat"
                android:textColor="@color/celestial_text"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_home_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="24 Jun" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btn_sky_shortcut"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="@id/home_title_icon_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/home_title_icon_container">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_sky"
                app:tint="@color/celestial_primary" />
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/celestial_border"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="112dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:id="@+id/home_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:id="@+id/header_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/layout_location_picker"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_capsule_inactive"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_location"
                        app:tint="@color/celestial_primary_strong" />

                    <TextView
                        android:id="@+id/tv_current_city"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="Detecting..."
                        android:textColor="@color/celestial_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_moon_pill"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_capsule_inactive"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_sky"
                        app:tint="@color/celestial_moon" />

                    <TextView
                        android:id="@+id/tv_moon_pill"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:textColor="@color/celestial_text"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Full Moon" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_loading_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="278dp"
                    android:background="@drawable/bg_hero_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <ProgressBar
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:indeterminateTint="@color/celestial_primary_strong" />

                    <TextView
                        android:id="@+id/tv_home_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:textColor="@color/celestial_text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Updating today’s flow" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_error_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_inline_notice"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wifi_off"
                    app:tint="@color/celestial_warning" />

                <TextView
                    android:id="@+id/tv_home_error_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:textColor="@color/celestial_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_home_error_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_home_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gold_button"
                    android:backgroundTint="@null"
                    app:backgroundTint="@null"
                    android:minWidth="132dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textColor="@color/celestial_on_gold"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/home_loaded_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/card_hero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_card"
                    android:elevation="4dp"
                    android:minHeight="316dp"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_hero_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_capsule_inactive"
                            android:drawablePadding="6dp"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="ACTIVE NOW"
                            android:textColor="@color/celestial_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_hero_ends_at"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/celestial_text_muted"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_hero_end_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="serif"
                                android:textColor="@color/celestial_primary"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                tools:text="8:00 AM" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/view_hero_color_dot"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/bg_circle_solid" />

                        <TextView
                            android:id="@+id/tv_hero_slot_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:fontFamily="serif"
                            android:singleLine="true"
                            android:text="Amrit"
                            android:textColor="@color/celestial_text"
                            android:textSize="42sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_hero_meaning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Best slot. Good for all auspicious works."
                        android:textColor="@color/celestial_text_muted"
                        android:textSize="15sp" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="14dp" />

                    <TextView
                        android:id="@+id/tv_hero_countdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="00:00:00"
                        android:textColor="@color/celestial_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/progress_hero"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/celestial_border"
                        android:progressTint="@color/celestial_primary_strong" />

                    <TextView
                        android:id="@+id/tv_hero_time_range"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="06:30 AM - 08:00 AM"
                        android:textColor="@color/celestial_outline"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/astronomy_strip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/card_sunrise"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_glass_card"
                        android:gravity="start|center_vertical"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_sparkles"
                            app:tint="@color/celestial_warning" />

                        <TextView
                            android:id="@+id/tv_sunrise_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="@color/celestial_text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="Sunrise" />

                        <TextView
                            android:id="@+id/tv_sunrise"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="--:--"
                            android:textColor="@color/celestial_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_sunset"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_glass_card"
                        android:gravity="start|center_vertical"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/celestial_primary" />

                        <TextView
                            android:id="@+id/tv_sunset_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="@color/celestial_text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="Sunset" />

                        <TextView
                            android:id="@+id/tv_sunset"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="--:--"
                            android:textColor="@color/celestial_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_provider"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_glass_card"
                        android:gravity="start|center_vertical"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_sky"
                            app:tint="@color/celestial_moon" />

                        <TextView
                            android:id="@+id/tv_provider_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="@color/celestial_text_muted"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="Source" />

                        <TextView
                            android:id="@+id/tv_provider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:text="Offline Cache"
                            android:textColor="@color/celestial_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/timeline_section_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_timeline_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/celestial_text"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="Today’s Path" />

                        <TextView
                            android:id="@+id/tv_timeline_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:singleLine="true"
                            android:textColor="@color/celestial_text_muted"
                            android:textSize="13sp"
                            tools:text="Highly auspicious" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_full_schedule"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_capsule_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:minWidth="112dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/celestial_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Full Schedule" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/upcoming_slots_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
