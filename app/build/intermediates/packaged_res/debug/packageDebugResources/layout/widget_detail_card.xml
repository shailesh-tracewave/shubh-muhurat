<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glass_card"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- LEFT HALF: Astro Grid 3x2 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:orientation="vertical">

        <!-- Top Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Sunrise -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sky"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sunrise"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_metric_sunrise_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5:55 AM"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/celestial_border"
                android:alpha="0.3" />

            <!-- Sunset -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sky"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sunset"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_metric_sunset_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7:18 PM"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/celestial_border"
                android:alpha="0.3" />

            <!-- Moonrise -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_clock"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moonrise"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_metric_moonrise_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3:07 PM"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/celestial_border"
            android:alpha="0.3" />

        <!-- Bottom Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Moonset -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_clock"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moonset"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_metric_moonset_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2:27 AM"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/celestial_border"
                android:alpha="0.3" />

            <!-- Solar Noon -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sky"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solar Noon"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_metric_noon_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:36 PM"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/celestial_border"
                android:alpha="0.3" />

            <!-- Illumination -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_sparkles"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Illumination"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_metric_illumination_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="77%"
                    android:textColor="@color/celestial_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="8dp"
        android:background="@color/celestial_border"
        android:alpha="0.3" />

    <!-- RIGHT HALF -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Top Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_detail_label_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp"
                    android:singleLine="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/widget_detail_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="6dp"
                        android:src="@drawable/bg_circle_solid" />

                    <TextView
                        android:id="@+id/widget_detail_active_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Udveg"
                        android:textColor="@color/celestial_text"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_detail_active_meaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="Tense"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>


        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Countdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/widget_detail_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01:18"
                android:textColor="@color/choghadiya_udveg"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_detail_label_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="4dp"
                android:text="Left"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/widget_detail_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="4dp"
            android:max="100"
            android:progress="60"
            android:progressTint="@color/choghadiya_udveg"
            android:progressBackgroundTint="@color/celestial_border" />

        <!-- Range -->
        <TextView
            android:id="@+id/widget_detail_active_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="9:57 PM - 11:17 PM"
            android:textColor="@color/celestial_text_muted"
            android:textSize="9sp"
            android:layout_marginBottom="4dp"
            android:singleLine="true" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/celestial_border"
            android:alpha="0.3"
            android:layout_marginBottom="4dp" />

        <!-- Next 3 Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next 3"
            android:textColor="@color/celestial_text_muted"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Col 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/widget_detail_next_1_dot"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:src="@drawable/bg_circle_solid"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:id="@+id/widget_detail_next_1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shubh"
                        android:textColor="@color/celestial_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_detail_next_1_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:36 AM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="8sp"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/celestial_border"
                android:alpha="0.3" />

            <!-- Col 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="4dp"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/widget_detail_next_2_dot"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:src="@drawable/bg_circle_solid"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:id="@+id/widget_detail_next_2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amrit"
                        android:textColor="@color/celestial_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_detail_next_2_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1:56 AM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="8sp"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/celestial_border"
                android:alpha="0.3" />

            <!-- Col 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="4dp"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/widget_detail_next_3_dot"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:src="@drawable/bg_circle_solid"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:id="@+id/widget_detail_next_3_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chal"
                        android:textColor="@color/celestial_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_detail_next_3_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3:15 AM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="8sp"
                    android:singleLine="true" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
