<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_card"
    android:orientation="horizontal"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_widget_sunrise" />

                <TextView
                    android:id="@+id/widget_metric_sunrise_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sunrise"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_sunrise_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="5:55"
                    android:textColor="@color/celestial_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_sunrise_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="AM"
                    android:textColor="@color/widget_metric_orange"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_widget_sunset" />

                <TextView
                    android:id="@+id/widget_metric_sunset_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sunset"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_sunset_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="7:28"
                    android:textColor="@color/celestial_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_sunset_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="PM"
                    android:textColor="@color/widget_metric_red"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_widget_moonrise" />

                <TextView
                    android:id="@+id/widget_metric_moonrise_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Moonrise"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_moonrise_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="4:35"
                    android:textColor="@color/celestial_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_moonrise_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="PM"
                    android:textColor="@color/celestial_moon"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/widget_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_widget_moonset" />

                <TextView
                    android:id="@+id/widget_metric_moonset_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Moonset"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_moonset_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="2:44"
                    android:textColor="@color/celestial_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_moonset_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="AM"
                    android:textColor="@color/celestial_moon"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_widget_noon" />

                <TextView
                    android:id="@+id/widget_metric_noon_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Solar Noon"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_noon_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="12:41"
                    android:textColor="@color/celestial_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_noon_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="PM"
                    android:textColor="@color/widget_metric_yellow"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_widget_illumination" />

                <TextView
                    android:id="@+id/widget_metric_illumination_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Illumination"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_metric_illumination_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="88%"
                    android:textColor="@color/celestial_text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginStart="7dp"
        android:layout_marginEnd="7dp"
        android:background="@color/widget_divider" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.18"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/widget_detail_dot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/bg_circle_solid" />

                <TextView
                    android:id="@+id/widget_detail_active_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:text="Char"
                    android:textColor="@color/celestial_text"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_detail_label_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_detail_active_meaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <Chronometer
                android:id="@+id/widget_detail_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="00:54"
                android:textColor="@color/widget_accent_blue"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_detail_label_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="5dp"
                android:text="Left"
                android:textColor="@color/celestial_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_detail_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progress="55"
            android:progressBackgroundTint="@color/widget_progress_track"
            android:progressTint="@color/widget_accent_blue" />

        <TextView
            android:id="@+id/widget_detail_active_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:text="5:46 PM - 7:28 PM"
            android:textColor="@color/celestial_text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:background="@color/widget_divider" />

        <TextView
            android:id="@+id/widget_detail_next_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next 3"
            android:textColor="@color/widget_metric_yellow"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/widget_detail_next_1_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/bg_circle_solid" />

                    <TextView
                        android:id="@+id/widget_detail_next_1_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:text="Rog"
                        android:textColor="@color/celestial_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_detail_next_1_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:text="7:28 PM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="2dp"
                android:paddingEnd="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/widget_detail_next_2_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/bg_circle_solid" />

                    <TextView
                        android:id="@+id/widget_detail_next_2_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:text="Kaal"
                        android:textColor="@color/celestial_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_detail_next_2_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:text="8:46 PM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/widget_detail_next_3_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/bg_circle_solid" />

                    <TextView
                        android:id="@+id/widget_detail_next_3_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:text="Labh"
                        android:textColor="@color/celestial_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:singleLine="true" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_detail_next_3_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:text="10:05 PM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="9sp"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
