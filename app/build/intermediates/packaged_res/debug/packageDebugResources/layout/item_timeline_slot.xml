<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:background="@drawable/bg_glass_card"
    android:gravity="center_vertical"
    android:minHeight="76dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <View
        android:id="@+id/view_slot_color_dot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_circle_solid" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_slot_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/celestial_text"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Amrit" />

            <TextView
                android:id="@+id/tv_slot_badge"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_capsule_inactive"
                android:ellipsize="end"
                android:gravity="center"
                android:maxWidth="112dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:textColor="@color/celestial_primary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="NEXT"
                tools:visibility="visible" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_slot_time_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/celestial_outline"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="6:30 AM - 8:00 AM" />
    </LinearLayout>
</LinearLayout>
