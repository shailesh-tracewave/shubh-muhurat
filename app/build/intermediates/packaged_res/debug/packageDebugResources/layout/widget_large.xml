<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_large_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_card"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_large_label_current"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Current"
            android:textColor="@color/celestial_text_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_large_active_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5:46 PM - 7:28 PM"
            android:textColor="@color/celestial_text_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:singleLine="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/widget_large_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_large_active_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:text="Char"
                android:textColor="@color/celestial_text"
                android:textSize="30sp"
                android:textStyle="bold"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <Chronometer
                android:id="@+id/widget_large_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="00:54"
                android:textColor="@color/widget_accent_blue"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_large_label_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="7dp"
                android:text="Left"
                android:textColor="@color/celestial_text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_large_active_meaning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:text="Normal"
        android:textColor="@color/celestial_text_muted"
        android:textSize="13sp"
        android:textStyle="bold"
        android:singleLine="true" />

    <ProgressBar
        android:id="@+id/widget_large_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="55"
        android:progressBackgroundTint="@color/widget_progress_track"
        android:progressTint="@color/widget_accent_blue" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@color/widget_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.45"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/ic_widget_sunrise" />

                <TextView
                    android:id="@+id/widget_large_metric_sunrise_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sunrise"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_sunrise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="5:55"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_sunrise_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="AM"
                    android:textColor="@color/widget_metric_orange"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/ic_widget_sunset" />

                <TextView
                    android:id="@+id/widget_large_metric_sunset_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sunset"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_sunset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="7:28"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_sunset_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="PM"
                    android:textColor="@color/widget_metric_red"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/ic_widget_noon" />

                <TextView
                    android:id="@+id/widget_large_metric_noon_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Solar Noon"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_noon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="12:41"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_noon_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="PM"
                    android:textColor="@color/widget_metric_yellow"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/widget_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/ic_widget_moonrise" />

                <TextView
                    android:id="@+id/widget_large_metric_moonrise_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Moonrise"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_moonrise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="4:35"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_moonrise_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="PM"
                    android:textColor="@color/celestial_moon"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/ic_widget_moonset" />

                <TextView
                    android:id="@+id/widget_large_metric_moonset_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Moonset"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_moonset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="2:44"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_moonset_meridiem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="AM"
                    android:textColor="@color/celestial_moon"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/widget_divider" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="27dp"
                    android:layout_height="27dp"
                    android:src="@drawable/ic_widget_illumination" />

                <TextView
                    android:id="@+id/widget_large_metric_phase_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Illumination"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/widget_large_metric_phase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="88%"
                    android:textColor="@color/celestial_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:background="@color/widget_divider" />

    <TextView
        android:id="@+id/widget_large_next_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Next 3"
        android:textColor="@color/widget_metric_yellow"
        android:textSize="12sp"
        android:textStyle="bold"
        android:singleLine="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.7"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/widget_large_next_1_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_large_next_1_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:text="Rog"
                android:textColor="@color/celestial_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_large_next_1_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7:28 PM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/widget_large_next_2_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_large_next_2_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:text="Kaal"
                android:textColor="@color/celestial_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_large_next_2_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8:46 PM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/widget_large_next_3_dot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_large_next_3_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:text="Labh"
                android:textColor="@color/celestial_text"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_large_next_3_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:05 PM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_large_auspicious_1_name"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_auspicious_1_time"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_auspicious_2_name"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_auspicious_2_time"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_inauspicious_1_name"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_inauspicious_1_time"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_inauspicious_2_name"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widget_large_inauspicious_2_time"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </LinearLayout>
</LinearLayout>
