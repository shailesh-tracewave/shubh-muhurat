<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_label_current"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current"
            android:textColor="@color/celestial_text_muted"
            android:textSize="11sp"
            android:singleLine="true" />

        <ImageView
            android:id="@+id/widget_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="7dp"
            android:src="@drawable/bg_circle_solid" />

        <TextView
            android:id="@+id/widget_active_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:text="Char"
            android:textColor="@color/celestial_text"
            android:textSize="23sp"
            android:textStyle="bold"
            android:singleLine="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_active_meaning"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="bottom"
        android:orientation="horizontal">

        <Chronometer
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="00:54"
            android:textColor="@color/widget_accent_blue"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_label_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="4dp"
            android:text="Left"
            android:textColor="@color/celestial_text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="6dp"
        android:max="100"
        android:progress="55"
        android:progressBackgroundTint="@color/widget_progress_track"
        android:progressTint="@color/widget_accent_blue" />

    <TextView
        android:id="@+id/widget_active_range"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:text="5:46 PM - 7:28 PM"
        android:textColor="@color/celestial_text_muted"
        android:textSize="11sp"
        android:textStyle="bold"
        android:singleLine="true" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@color/widget_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/widget_next_1_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginBottom="3dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_next_1_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:text="Rog"
                android:textColor="@color/celestial_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_next_1_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:text="7:28 PM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/widget_next_2_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginBottom="3dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_next_2_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:text="Kaal"
                android:textColor="@color/celestial_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_next_2_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:text="8:46 PM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/widget_next_3_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginBottom="3dp"
                android:src="@drawable/bg_circle_solid" />

            <TextView
                android:id="@+id/widget_next_3_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:text="Labh"
                android:textColor="@color/celestial_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/widget_next_3_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:text="10:05 PM"
                android:textColor="@color/celestial_text_muted"
                android:textSize="10sp"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
