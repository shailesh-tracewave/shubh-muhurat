<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Adaptive Card Background for Light/Dark Mode and Perfect Shadows -->
    <solid android:color="@color/celestial_card_background" />
    
    <!-- 1dp Gold Rim Lighting Stroke -->
    <stroke
        android:width="1dp"
        android:color="#38D4AF37" /> <!-- #D4AF37 at 22% opacity -->
        
    <!-- Soft Organic Roundedness -->
    <corners android:radius="24dp" />
</shape>
