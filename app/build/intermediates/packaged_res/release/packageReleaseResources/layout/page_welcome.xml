<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celestial_background"
    android:padding="20dp">

    <!-- Sparkles Visual Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/visual_container"
        android:layout_width="168dp"
        android:layout_height="168dp"
        android:layout_marginTop="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/circle_stroke"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_stroke" />

        <View
            android:id="@+id/circle_solid"
            android:layout_width="154dp"
            android:layout_height="154dp"
            android:background="@drawable/bg_onboarding_disc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/inapp_logo"
            app:shapeAppearanceOverlay="@style/CircleImageView"
            app:strokeColor="@color/celestial_primary_strong"
            app:strokeWidth="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Heading & Body -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="Know the right time"
        android:textColor="@color/celestial_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/visual_container" />

    <TextView
        android:id="@+id/tv_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Align your daily actions with cosmic rhythms effortlessly."
        android:textColor="@color/celestial_text_muted"
        android:textSize="17sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Feature Grid -->
    <LinearLayout
        android:id="@+id/features_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_body">

        <!-- Card 1: Widgets -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="14dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_widget" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="LOCK WIDGETS"
                android:textColor="@color/celestial_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Lock screen and home widgets display timings instantly."
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Card 2: Offline -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="14dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_wifi_off" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="OFFLINE ACCESS"
                android:textColor="@color/celestial_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Robust offline cache keeps you guided without network."
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Page indicators & Action footer -->
    <LinearLayout
        android:id="@+id/footer_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <!-- Capsule Page Indicator -->
            <View
                android:layout_width="30dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_capsule_active"
                android:layout_marginEnd="6dp" />
            <View
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_capsule_inactive"
                android:layout_marginEnd="6dp" />
            <View
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_capsule_inactive" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_continue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_gold_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="CONTINUE"
            android:textColor="@color/celestial_on_gold"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
