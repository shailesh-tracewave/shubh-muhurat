<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celestial_background"
    android:padding="20dp">

    <!-- Clock Visual Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/visual_container"
        android:layout_width="132dp"
        android:layout_height="132dp"
        android:layout_marginTop="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/circle_stroke"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_stroke" />

        <View
            android:id="@+id/circle_solid"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:background="@drawable/bg_onboarding_disc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:src="@drawable/ic_sparkles"
            app:tint="@color/celestial_primary_strong"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Heading & Body -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="Follow the real flow, not a static table"
        android:textColor="@color/celestial_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/visual_container" />

    <TextView
        android:id="@+id/tv_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="The app shows the current slot plus the next six chronological slots, including night Choghadiya after midnight."
        android:textColor="@color/celestial_text_muted"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Timeline Stream Visualizer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timeline_stream"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_body">

        <!-- Left stream connector line -->
        <View
            android:id="@+id/connector_line"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_marginStart="30dp"
            android:background="#1AD4AF37"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Card 1: Amrit (Active Now) -->
        <LinearLayout
            android:id="@+id/slot_amrit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_circle_solid"
                android:backgroundTint="@color/choghadiya_amrit"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="Amrit"
                        android:textColor="@color/choghadiya_amrit"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_capsule_active"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="ACTIVE NOW"
                        android:textColor="@color/celestial_on_gold"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="06:30 AM - 08:00 AM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 2: Shubh -->
        <LinearLayout
            android:id="@+id/slot_shubh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:alpha="0.8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/slot_amrit">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_circle_solid"
                android:backgroundTint="@color/choghadiya_shubh"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="17dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:text="Shubh"
                        android:textColor="@color/choghadiya_shubh"
                        android:textSize="20sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_capsule_inactive"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="NEXT"
                        android:textColor="@color/celestial_primary"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="08:00 AM - 09:30 AM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 3: Labh -->
        <LinearLayout
            android:id="@+id/slot_labh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:alpha="0.6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/slot_shubh">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_circle_solid"
                android:backgroundTint="@color/choghadiya_labh"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="17dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="Labh"
                    android:textColor="@color/choghadiya_labh"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="09:30 AM - 11:00 AM"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Page indicators & Action footer -->
    <LinearLayout
        android:id="@+id/footer_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <!-- Capsule Page Indicator -->
            <View
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_capsule_inactive"
                android:layout_marginEnd="6dp" />
            <View
                android:layout_width="30dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_capsule_active"
                android:layout_marginEnd="6dp" />
            <View
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_capsule_inactive" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_continue_timeline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_gold_button"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="NEXT"
            android:textColor="@color/celestial_on_gold"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
