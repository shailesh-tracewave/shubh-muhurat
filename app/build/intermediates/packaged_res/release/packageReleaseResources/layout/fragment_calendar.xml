<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celestial_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/calendar_header"
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="@color/celestial_background"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/calendar_title_icon_container"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_circle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_calendar"
                app:tint="@color/celestial_primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/calendar_title_icon_container"
            app:layout_constraintEnd_toStartOf="@id/btn_calendar_today"
            app:layout_constraintStart_toEndOf="@id/calendar_title_icon_container"
            app:layout_constraintTop_toTopOf="@id/calendar_title_icon_container">

            <TextView
                android:id="@+id/tv_calendar_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="serif"
                android:singleLine="true"
                android:textColor="@color/celestial_text"
                android:textSize="26sp"
                android:textStyle="bold"
                tools:text="Calendar" />

            <TextView
                android:id="@+id/tv_calendar_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/celestial_text_muted"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Ahmedabad" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_calendar_today"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:background="@drawable/bg_capsule_inactive"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minWidth="88dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/celestial_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="Active Now"
            app:layout_constraintBottom_toBottomOf="@id/calendar_title_icon_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/calendar_title_icon_container" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/celestial_border"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/calendar_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="132dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/calendar_header">

        <LinearLayout
            android:id="@+id/calendar_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp">

            <LinearLayout
                android:id="@+id/calendar_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_month_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:fontFamily="serif"
                        android:singleLine="true"
                        android:text="June 2026"
                        android:textColor="@color/celestial_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_prev_month"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_icon_circle"
                        android:contentDescription="@null"
                        android:padding="9dp"
                        android:src="@drawable/ic_chevron_left"
                        app:tint="@color/celestial_primary" />

                    <ImageButton
                        android:id="@+id/btn_next_month"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_circle"
                        android:contentDescription="@null"
                        android:padding="9dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/celestial_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_weekdays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal" />

                <GridView
                    android:id="@+id/calendar_grid"
                    android:layout_width="match_parent"
                    android:layout_height="330dp"
                    android:layout_marginTop="10dp"
                    android:clipToPadding="false"
                    android:gravity="center"
                    android:horizontalSpacing="6dp"
                    android:numColumns="7"
                    android:overScrollMode="never"
                    android:scrollbars="none"
                    android:stretchMode="columnWidth"
                    android:verticalSpacing="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_sparkles"
                        app:tint="@color/celestial_primary_strong" />

                    <TextView
                        android:id="@+id/tv_calendar_legend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/celestial_text_muted"
                        android:textSize="13sp"
                        tools:text="Dots show auspicious, neutral, and caution periods" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/calendar_loading_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_inline_notice"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:indeterminateTint="@color/celestial_primary_strong" />

                <TextView
                    android:id="@+id/tv_calendar_loading"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="Updating calendar" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/calendar_error_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_inline_notice"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="22dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wifi_off"
                    app:tint="@color/celestial_warning" />

                <TextView
                    android:id="@+id/tv_calendar_error_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:textColor="@color/celestial_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_calendar_error_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_calendar_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_gold_button"
                    android:backgroundTint="@null"
                    app:backgroundTint="@null"
                    android:minWidth="132dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textColor="@color/celestial_on_gold"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/scroll_day_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_selected_date_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="1 June 2026"
                    android:textColor="@color/celestial_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_day_night_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="14sp"
                    tools:text="Daytime and nighttime Choghadiya flow" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/celestial_border" />

                <TextView
                    android:id="@+id/tv_daytime_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="DAYTIME"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/daytime_slots_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_nighttime_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="NIGHTTIME"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/nighttime_slots_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_paywall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_inline_notice"
                android:elevation="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_widget"
                    app:tint="@color/celestial_primary" />

                <TextView
                    android:id="@+id/tv_paywall_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:text="Celestial Premium"
                    android:textColor="@color/celestial_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_paywall_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:textColor="@color/celestial_text_muted"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_unlock_calendar"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_gold_button"
                    android:backgroundTint="@null"
                    app:backgroundTint="@null"
                    android:minWidth="160dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:textColor="@color/celestial_on_gold"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
